---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, readingTime, slugifyTaxonomy } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.hidden !== true);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const minutes = readingTime(post.body);
const toc = headings.filter((heading) => heading.depth > 1 && heading.depth < 4);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="post-layout">
    <header class="article-head">
      <div class="post-meta">
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
        <span>{minutes} min read</span>
      </div>
      <h1>{post.data.title}</h1>
      {post.data.description && <p>{post.data.description}</p>}
      <div class="tag-row">
        {post.data.categories.map((category) => <a href={`/categories/${slugifyTaxonomy(category)}/`}>{category}</a>)}
        {post.data.tags.map((tag) => <a href={`/tags/${slugifyTaxonomy(tag)}/`}>#{tag}</a>)}
      </div>
    </header>

    <div class="article-grid">
      <div class="article-content">
        <Content />
      </div>
      {toc.length > 0 && (
        <aside class="toc" aria-label="Table of contents">
          <p>On this page</p>
          <nav>
            {toc.map((heading) => (
              <a class={`depth-${heading.depth}`} href={`#${heading.slug}`}>{heading.text}</a>
            ))}
          </nav>
        </aside>
      )}
    </div>
  </article>
</BaseLayout>

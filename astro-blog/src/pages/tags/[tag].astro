---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPosts, slugifyTaxonomy, uniqueSorted } from '../../lib/posts';

const allPosts = await getPosts();

export async function getStaticPaths() {
  const posts = await getPosts();
  return uniqueSorted(posts.flatMap((post) => post.data.tags)).map((tag) => ({
    params: { tag: slugifyTaxonomy(tag) },
    props: { tag }
  }));
}

const { tag } = Astro.props;
const posts = allPosts.filter((post) => post.data.tags.includes(tag));
---

<BaseLayout title={`#${tag}`}>
  <section class="page-head">
    <p class="eyebrow">Tag</p>
    <h1>#{tag}</h1>
  </section>
  <section class="post-list">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
